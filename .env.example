# =============================================================================
# DocQA — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by docker-compose to initialise the database and by the backend to
# connect.  The DATABASE_URL is assembled from these parts inside compose.
# -----------------------------------------------------------------------------
POSTGRES_USER=docqa
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=docqa_db

# Full async connection URL (overridden by docker-compose to use service name)
DATABASE_URL=postgresql+asyncpg://docqa:change_me_in_production@localhost:5432/docqa_db

# -----------------------------------------------------------------------------
# Redis
# Used for token blacklisting, document-list caching, and summary caching.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security — JWT
# SECRET_KEY must be a long random string.  Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=replace_with_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# OpenAI
# Required for GPT-4o chat completions, Whisper transcription, and embeddings.
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Pinecone
# Vector database for storing and querying document embeddings.
# Create a Serverless index at https://app.pinecone.io
# PINECONE_ENVIRONMENT is the cloud region, e.g. us-east-1
# -----------------------------------------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=docqa-index
PINECONE_ENVIRONMENT=us-east-1

# -----------------------------------------------------------------------------
# File uploads
# UPLOAD_DIR is the directory where uploaded files are stored on disk.
# In Docker this maps to the ./uploads host volume.
# MAX_FILE_SIZE_MB applies to all uploaded files.
# -----------------------------------------------------------------------------
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins, or a JSON array.
# Examples:
#   CORS_ORIGINS=http://localhost:3000
#   CORS_ORIGINS=https://app.example.com,https://www.example.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Application
# Set DEBUG=true to enable /docs and /redoc Swagger UI.
# Do NOT enable in production.
# -----------------------------------------------------------------------------
DEBUG=false
