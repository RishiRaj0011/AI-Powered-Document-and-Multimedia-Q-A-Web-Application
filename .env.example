# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# This file is used by docker-compose.yml for container orchestration
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=docqa
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=docqa_db

# Note: Backend will use these values to construct DATABASE_URL automatically
# Format: postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
