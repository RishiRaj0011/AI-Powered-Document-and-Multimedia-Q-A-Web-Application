# =============================================================================
# Backend Application Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# Application Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_64_characters_minimum
DEBUG=false

# -----------------------------------------------------------------------------
# Database Configuration (Docker Network)
# -----------------------------------------------------------------------------
# When running with docker-compose, use service name 'postgres' as host
DATABASE_URL=postgresql+asyncpg://docqa:your_password@postgres:5432/docqa_db

# For local development without Docker:
# DATABASE_URL=postgresql+asyncpg://docqa:password@localhost:5432/docqa_db

# -----------------------------------------------------------------------------
# Redis Configuration (Docker Network)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# For local development without Docker:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------

# Google Gemini (Primary - Recommended)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001

# OpenAI (Optional - Fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Vector Database Configuration
# -----------------------------------------------------------------------------
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=multimedia-rag-v2

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list or JSON array
CORS_ORIGINS=["http://localhost:3000"]

# For production, add your domain:
# CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=["pdf","mp3","mp4","wav","m4a","docx","txt","webm"]

# -----------------------------------------------------------------------------
# JWT Token Configuration
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Optional: Advanced Configuration
# -----------------------------------------------------------------------------
# UPLOAD_DIR=/uploads
# CACHE_TTL=3600
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
